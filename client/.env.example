# Frontend environment (Vite). Copy to ".env" for local dev, and set the same
# key in your host's build settings (Netlify/Vercel) for production.
# IMPORTANT: Vite only exposes vars prefixed with VITE_, and bakes them in at
# BUILD time — you must redeploy after changing this.

# Local development:
# VITE_API_URL=http://localhost:5000/api

# Production (point at your deployed backend):
VITE_API_URL=https://api.shafay.online/api
