# Backend environment. Copy to ".env" for local dev. In production (Render),
# set these in the dashboard under Environment — do NOT commit real values.

# --- Database (MongoDB Atlas M0) ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
ADMIN_SECRET_CODE=your-admin-signup-code

# --- Frontend origin ---
# Canonical site URL: used both for CORS and for links inside verification /
# password-reset emails. Use https and NO trailing slash.
CLIENT_URL=https://shafay.online
# Optional extra CORS origins (comma-separated), e.g. the www variant.
ALLOWED_ORIGINS=https://www.shafay.online

# --- PORT ---
# Leave UNSET on Render (it injects PORT automatically). Set locally if needed.
# PORT=5000

# --- Email (SMTP) ---
# If SMTP_HOST is left blank, a throwaway Ethereal account is used in dev and a
# preview link is logged (no real delivery). For real emails, e.g. Namecheap:
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=contact@shafay.online
SMTP_PASS=your-mailbox-password
FROM_NAME=ShafayStore
FROM_EMAIL=contact@shafay.online
